---
/**
 * Speakable Schema Component.
 *
 * Adds Article schema with SpeakableSpecification + linked @id references
 * back to the site-wide Organization + Person + WebSite graph that
 * SchemaGraph.astro emits.
 *
 * Speakable adoption is under 10% globally. Sites that ship it see a
 * meaningful lift in AI search referrals.
 */

import type { SiteConfig } from "../types/manifest";

interface Props {
  title: string;
  description: string;
  site: SiteConfig;
  datePublished?: string;
  dateModified?: string;
  url?: string;
  cssSelectors?: string[];
}

const {
  title,
  description,
  site,
  datePublished,
  // ISO 8601 with TZ. Date-only inputs are coerced.
  dateModified: dateModifiedRaw = new Date().toISOString(),
  url,
  // Expanded default cssSelectors per finding #13 (May 2026 research):
  // - .answer-capsule + .key-takeaway are explicit content classes
  // - h2 + p:first-of-type captures answer-first passages (Wellows 2026:
  //   62% of featured AI Overview extracts land in 134-167 word band,
  //   typically the first paragraph under each H2).
  // - .answer-first lets editorial mark passages as citation-grade.
  // Multi-target is allowed by spec. Each target should be <100 words.
  cssSelectors = [".answer-capsule", ".key-takeaway", ".answer-first", "h2 + p:first-of-type"]
} = Astro.props;

const dateModified = /^\d{4}-\d{2}-\d{2}$/.test(dateModifiedRaw)
  ? new Date(dateModifiedRaw + 'T00:00:00Z').toISOString()
  : dateModifiedRaw;

const siteUrl = site.siteUrl.replace(/\/$/, '');
const pageUrl = url || new URL(Astro.url.pathname, siteUrl).href;
const authorId = `${siteUrl}/#${site.author.name.toLowerCase().replace(/\s+/g, '-')}`;

const articleSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": pageUrl + "#article",
  "headline": title,
  "description": description,
  "dateModified": dateModified,
  "url": pageUrl,
  "isPartOf": { "@id": siteUrl + "/#website" },
  "author": {
    "@type": "Person",
    "@id": authorId,
    "name": site.author.name,
    "jobTitle": site.author.role,
    "description": site.author.bio
  },
  "publisher": { "@id": siteUrl + "/#organization" },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": cssSelectors
  }
};

if (datePublished) articleSchema.datePublished = datePublished;
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
