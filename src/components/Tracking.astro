---
/**
 * Tracking: analytics + behavioural tracking, fleet-wide pattern.
 *
 * Reads from site.manifest.ts → SiteConfig.tracking → { ga4?, clarity?, gtm? }.
 * Each provider renders only if its ID is present. No emission if unset.
 *
 * Loads after partytown for service-worker isolation where the site has it
 * (Partytown wraps the gtag/clarity calls, keeping the main thread clean).
 *
 * Drop into <head> of every BaseLayout:
 *   <Tracking site={site} />
 *
 * Adam follow-up: create the property in each provider's admin UI, paste
 * the ID into site.manifest.ts.
 */

import type { SiteConfig } from "../types/manifest";

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
const ga4 = site.tracking?.ga4;
const clarity = site.tracking?.clarity;
const gtm = site.tracking?.gtm;
---

{ga4 && (
  <>
    <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${ga4}`}></script>
    <script type="text/partytown" set:html={`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '${ga4}', { anonymize_ip: true });
    `} />
  </>
)}

{clarity && (
  <script type="text/partytown" set:html={`
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "${clarity}");
  `} />
)}

{gtm && (
  <>
    <script type="text/partytown" set:html={`
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','${gtm}');
    `} />
    <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${gtm}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
  </>
)}
