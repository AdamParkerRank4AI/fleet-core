---
/**
 * Tracking: analytics + behavioural tracking, fleet-wide pattern.
 *
 * Reads from site.manifest.ts → SiteConfig.tracking → { ga4?, clarity?, gtm? }.
 * Each provider renders only if its ID is present.
 *
 * Loaded via partytown for service-worker isolation (when site has partytown).
 *
 * Drop into <head> of every BaseLayout:
 *   <Tracking site={site} />
 */

import type { SiteConfig } from "../types/manifest";

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
const ga4 = site.tracking?.ga4;
const clarity = site.tracking?.clarity;
const gtm = site.tracking?.gtm;

// Pre-compute inline JS strings in frontmatter so Astro doesn't mis-parse
// window/document references as SSR code.
const ga4Inline = ga4
  ? `window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${ga4}', { anonymize_ip: true });`
  : null;

const clarityInline = clarity
  ? `(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","${clarity}");`
  : null;

const gtmInline = gtm
  ? `(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtm}');`
  : null;

const gtmNoscript = gtm
  ? `<iframe src="https://www.googletagmanager.com/ns.html?id=${gtm}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`
  : null;
---

{ga4 && <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${ga4}`}></script>}
{ga4Inline && <script type="text/partytown" set:html={ga4Inline} />}

{clarityInline && <script type="text/partytown" set:html={clarityInline} />}

{gtmInline && <script type="text/partytown" set:html={gtmInline} />}
{gtmNoscript && <noscript set:html={gtmNoscript} />}
