    font-size: var(--fc-fs-sm);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: calc(-1 * var(--fc-sp-3));
  }
  .fc-leadform__required { color: #fca5a5; }
  .fc-leadform__input {
    width: 100%;
    padding: var(--fc-sp-3) var(--fc-sp-4);
    border-radius: var(--fc-radius);
