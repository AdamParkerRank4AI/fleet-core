---
/**
 * LeadForm — fleet-canonical lead capture form (v0.8.0 — light card + chips + director + trading-time).
 *
 * Why this version (vs v0.7.0):
 *   - Visual: white card on cream surface (was dark navy), slim segmented
 *     progress bar (was "Step 1 of 2" text), £-prefix input + chip presets
 *     (was 5-tile band grids), pill chips for finance type (was tile grid),
 *     inline email validation with green tick + disabled-state Continue.
 *   - Functional: director field auto-loaded from Companies House officers
 *     (with "type their name instead" fallback), trading-time pill selector,
 *     progressive disclosure on turnover ("higher than this?" → reveals
 *     monthly revenue field), bottom-pinned Back + Continue row.
 *
 * Step structure (unchanged from v0.7):
 *   Step 1 — company + director + trading time + amount + turnover + finance
 *   Step 2 — name + email + phone
 *
 * Partial-fill email, abandon timer, Supabase 3-tier write, attribution +
 * big-tracking blob, server-side enrichment — all preserved from v0.7.0.
 *
 * Companies House endpoints required on host CF Pages:
 *   /api/companies-house/search  — required for the autocomplete
 *   /api/companies-house/officers — required for the director dropdown (new)
 *   /api/lead-enrich              — optional, for server-side IP/geo/ASN
 *
 * BREAKING CHANGE vs v0.7: the form posts EXACT amount + turnover (numeric
 * strings), not band labels. Brokers downstream get precise figures.
 *
 * Config shape: v0.7 `financeTypes`/`turnoverBands`/`amountBands` still
 * accepted for back-compat, but new sites should use `financeChips`,
 * `turnoverChips`, `amountChips`, `tradingChips` (numeric chip presets).
 */

interface ChipOption {
  value: string | number;
  label: string;
}

export interface LeadFormConfig {
  submitEndpoint: string;
  partialFillEmail?: string;
  emailSubject?: string;
  supabase?: { url: string; anonKey: string; table: string };
  /** Path to same-origin Companies House search proxy. Default: `/api/companies-house/search`. */
  companiesHouseProxyPath?: string | null;
  /** Path to same-origin Companies House officers proxy. Default: `/api/companies-house/officers`. */
  companiesHouseOfficersPath?: string | null;
  /** Path to same-origin server-side enrichment endpoint. Default: `/api/lead-enrich`. */
  enrichPath?: string | null;

  /** v0.8 chip presets — preferred shape. */
  amountChips?: ChipOption[];
  turnoverChips?: ChipOption[];
  financeChips?: ChipOption[];
  tradingChips?: ChipOption[];

  /** v0.7 back-compat names — quietly mapped to chips at runtime. */
  amountBands?: ChipOption[];
  turnoverBands?: ChipOption[];
  financeTypes?: ChipOption[];
  industries?: ChipOption[]; // legacy, unused

  trustPills?: string[];
  successHTML?: string;
  privacyPath?: string;
  attributionKey?: string;

  /** Copy shown under the "Can't find your business?" link. */
  cantFindMessage?: string;
}

interface Props {
  config: LeadFormConfig;
  heading?: string;
  subheading?: string;
  brokerDisclosure?: string;
  appliedFrom?: string;
  defaultFinanceType?: string;
  defaultAmount?: string;
  defaultTurnover?: string;
  defaultIndustry?: string;
  lenderContext?: string;
}

const {
  config,
  heading = "Check your funding options",
  subheading,
  brokerDisclosure,
  appliedFrom,
  defaultFinanceType,
  defaultAmount,
  defaultTurnover,
  lenderContext,
} = Astro.props;

const resolvedAppliedFrom = appliedFrom || Astro.url.pathname;

const DEFAULT_AMOUNT_CHIPS: ChipOption[] = [
  { value: 25000,  label: "£25,000" },
  { value: 50000,  label: "£50,000" },
  { value: 100000, label: "£100,000" },
  { value: 250000, label: "£250,000" },
];
const DEFAULT_TURNOVER_CHIPS: ChipOption[] = [
  { value: 5000,   label: "£5,000" },
  { value: 25000,  label: "£25,000" },
  { value: 50000,  label: "£50,000" },
  { value: 100000, label: "£100,000" },
];
const DEFAULT_TRADING_CHIPS: ChipOption[] = [
  { value: "under-6m", label: "Under 6 months" },
  { value: "6-12m",    label: "6 to 12 months" },
  { value: "1-2y",     label: "1 to 2 years" },
  { value: "2-5y",     label: "2 to 5 years" },
  { value: "5y-plus",  label: "5 years +" },
];

const amountChips    = config.amountChips    || config.amountBands    || DEFAULT_AMOUNT_CHIPS;
const turnoverChips  = config.turnoverChips  || config.turnoverBands  || DEFAULT_TURNOVER_CHIPS;
const financeChips   = config.financeChips   || config.financeTypes   || [];
const tradingChips   = config.tradingChips   || DEFAULT_TRADING_CHIPS;

const clientConfig = {
  submitEndpoint: config.submitEndpoint,
  partialFillEmail: config.partialFillEmail || null,
  emailSubject: config.emailSubject || "New lead",
  supabase: config.supabase || null,
  companiesHouseProxyPath:
    config.companiesHouseProxyPath === null
      ? null
      : config.companiesHouseProxyPath || "/api/companies-house/search",
  companiesHouseOfficersPath:
    config.companiesHouseOfficersPath === null
      ? null
      : config.companiesHouseOfficersPath || "/api/companies-house/officers",
  enrichPath:
    config.enrichPath === null
      ? null
      : config.enrichPath || "/api/lead-enrich",
  attributionKey: config.attributionKey || "fc_first_touch",
  appliedFrom: resolvedAppliedFrom,
  cantFindMessage:
    config.cantFindMessage ||
    "If your business isn't on Companies House (sole trader, partnership of 3 or fewer, or unincorporated) we'll route you to the right form on our broader network.",
  successHTML:
    config.successHTML ||
    '<div style="text-align:center; padding:3rem 1rem;"><h3 style="font-family: var(--fc-font-display, Georgia, serif); font-size: 1.6rem; font-weight: 800; margin: 0 0 0.6rem;">Thank you</h3><p style="color: var(--fc-text-muted, #4a5568); margin: 0;">We\'ll be in touch within 24 hours with matched UK lender options.</p></div>',
  privacyPath: config.privacyPath || "/privacy/",
};
---

<section class="fc-leadform" data-fc-leadform>
  <div class="fc-leadform__inner">
    <div class="fc-leadform__head">
      <h2 class="fc-leadform__heading">{heading}</h2>
    </div>

    {subheading && <p class="fc-leadform__sub">{subheading}</p>}
    {brokerDisclosure && <p class="fc-leadform__disclosure">{brokerDisclosure}</p>}

    {/* Segmented progress bar — 2 segments for the 2 steps */}
    <div class="fc-leadform__progress" role="progressbar" aria-valuemin="0" aria-valuemax="2" aria-valuenow="1">
      <span class="fc-leadform__progress-seg fc-leadform__progress-seg--active" data-seg="1"></span>
      <span class="fc-leadform__progress-seg" data-seg="2"></span>
    </div>

    <form id="fc-lead-form" class="fc-leadform__form" novalidate>
      <input type="hidden" name="applied_from" value={resolvedAppliedFrom} />
      <input type="hidden" name="applied_from_url" id="fc-applied-from-url" />
      {lenderContext && <input type="hidden" name="lender_context" value={lenderContext} />}

      {/* STEP 1 */}
      <div id="fc-step-1" class="fc-leadform__step">

        {/* Field: Company (Companies House autocomplete) */}
        <div class="fc-leadform__field">
          <label class="fc-leadform__label" for="fc-company">What's your business name? <span class="fc-leadform__required">*</span></label>
          <p class="fc-leadform__helper">Start typing — we'll search Companies House.</p>
          <div class="fc-leadform__autocomplete">
            <input type="text" id="fc-company" name="company" required autocomplete="organization"
              class="fc-leadform__input"
              placeholder="Start typing your registered company name…" />
            <div id="fc-ch-results" class="fc-leadform__autocomplete-results" hidden></div>
          </div>
          <input type="hidden" id="fc-company-number" name="company_number" />
          <input type="hidden" id="fc-company-status" name="company_status" />
          <input type="hidden" id="fc-business-postcode" name="business_postcode" />
          <p id="fc-ch-info" class="fc-leadform__field-info" hidden></p>
          <p id="fc-company-error" class="fc-leadform__error" hidden>Please pick your business from the list.</p>

          <button type="button" id="fc-cant-find" class="fc-leadform__link-btn">
            Can't find your business?
          </button>

          {/* Manual path — hidden until "can't find" is clicked */}
          <div id="fc-manual-mode" class="fc-leadform__manual" hidden>
            <p class="fc-leadform__manual-info">{clientConfig.cantFindMessage}</p>
            <label class="fc-leadform__label" for="fc-business-postcode-visible">
              Business postcode <span class="fc-leadform__required">*</span>
            </label>
            <input type="text" id="fc-business-postcode-visible" autocomplete="postal-code"
              class="fc-leadform__input" placeholder="e.g. SW1A 1AA"
              inputmode="text" maxlength="10" />
            <p id="fc-business-postcode-visible-error" class="fc-leadform__error" hidden>Please enter a valid UK postcode.</p>
            <button type="button" id="fc-back-to-autocomplete" class="fc-leadform__link-btn">
              ← Try Companies House search again
            </button>
          </div>
        </div>

        {/* Field: Director (auto-populated from CH officers after company selected) */}
        <div id="fc-director-field" class="fc-leadform__field" hidden>
          <label class="fc-leadform__label" for="fc-director">Select a director</label>
          <p class="fc-leadform__helper">Required by lenders to confirm authority.</p>
          <select id="fc-director" name="director" class="fc-leadform__input fc-leadform__select">
            <option value="">Loading directors…</option>
          </select>
          <button type="button" id="fc-director-manual-toggle" class="fc-leadform__link-btn">
            Director not in the list? Type their name instead.
          </button>
          <div id="fc-director-manual" hidden>
            <input type="text" id="fc-director-manual-input" name="director_manual"
              class="fc-leadform__input" placeholder="e.g. Jane Smith"
              autocomplete="off" />
            <button type="button" id="fc-director-back-to-list" class="fc-leadform__link-btn">
              ← Back to director list
            </button>
          </div>
        </div>

        {/* Field: Trading time */}
        <div class="fc-leadform__field">
          <label class="fc-leadform__label">How long have you been trading?</label>
          <div class="fc-leadform__pills" data-pill-group="trading">
            {tradingChips.map(c => (
              <button type="button" class="fc-leadform__pill" data-value={c.value}>{c.label}</button>
            ))}
          </div>
          <input type="hidden" id="fc-trading" name="trading_time" />
          <p id="fc-trading-error" class="fc-leadform__error" hidden>Please pick how long you've been trading.</p>
        </div>

        {/* Field: Amount (£ input + chip presets) */}
        <div class="fc-leadform__field">
          <label class="fc-leadform__label" for="fc-amount">How much funding are you looking for?</label>
          <div class="fc-leadform__currency-input">
            <span class="fc-leadform__currency-prefix">£</span>
            <input type="text" id="fc-amount" name="amount" inputmode="numeric"
              class="fc-leadform__input fc-leadform__input--currency"
              placeholder="50,000" value={defaultAmount || ""} />
          </div>
          <div class="fc-leadform__chips">
            {amountChips.map(c => (
              <button type="button" class="fc-leadform__chip" data-target="fc-amount" data-value={c.value}>{c.label}</button>
            ))}
          </div>
          <p class="fc-leadform__helper">You can also type a custom amount.</p>
          <p id="fc-amount-error" class="fc-leadform__error" hidden>Please enter an amount.</p>
        </div>

        {/* Field: Monthly turnover (£ input + chips + progressive disclosure) */}
        <div class="fc-leadform__field">
          <label class="fc-leadform__label" for="fc-turnover">Estimated monthly turnover</label>
          <p class="fc-leadform__helper">An estimate is fine.</p>
          <div class="fc-leadform__currency-input">
            <span class="fc-leadform__currency-prefix">£</span>
            <input type="text" id="fc-turnover" name="turnover" inputmode="numeric"
              class="fc-leadform__input fc-leadform__input--currency"
              placeholder="50,000" value={defaultTurnover || ""} />
          </div>
          <div class="fc-leadform__chips">
            {turnoverChips.map(c => (
              <button type="button" class="fc-leadform__chip" data-target="fc-turnover" data-value={c.value}>{c.label}</button>
            ))}
          </div>

          <div id="fc-turnover-followup" class="fc-leadform__followup" hidden>
            <p class="fc-leadform__label fc-leadform__label--inline">Is your turnover currently higher than this?</p>
            <div class="fc-leadform__radio-row">
              <label class="fc-leadform__radio">
                <input type="radio" name="turnover_higher" value="yes" /> Yes
              </label>
              <label class="fc-leadform__radio">
                <input type="radio" name="turnover_higher" value="no" /> No
              </label>
            </div>
            <div id="fc-monthly-revenue-field" class="fc-leadform__sub-field" hidden>
              <label class="fc-leadform__label" for="fc-monthly-revenue">What's your current average monthly revenue?</label>
              <div class="fc-leadform__currency-input">
                <span class="fc-leadform__currency-prefix">£</span>
                <input type="text" id="fc-monthly-revenue" name="monthly_revenue" inputmode="numeric"
                  class="fc-leadform__input fc-leadform__input--currency"
                  placeholder="200,000" />
              </div>
            </div>
          </div>

          <p id="fc-turnover-error" class="fc-leadform__error" hidden>Please enter monthly turnover.</p>
        </div>

        {/* Field: Finance type (horizontal pill chips) */}
        <div class="fc-leadform__field">
          <label class="fc-leadform__label">What's it for?</label>
          <div class="fc-leadform__pills" data-pill-group="finance">
            {financeChips.map(c => (
              <button type="button" class="fc-leadform__pill" data-value={c.value} data-default={defaultFinanceType === String(c.value) ? "1" : "0"}>{c.label}</button>
            ))}
          </div>
          <input type="hidden" id="fc-finance-type" name="finance_type" />
          <p id="fc-finance-type-error" class="fc-leadform__error" hidden>Please pick what the finance is for.</p>
        </div>
      </div>

      {/* STEP 2 */}
      <div id="fc-step-2" class="fc-leadform__step" hidden>
        <p class="fc-leadform__step2-recap" id="fc-step2-recap"></p>

        <div class="fc-leadform__field">
          <label class="fc-leadform__label" for="fc-name">Your name <span class="fc-leadform__required">*</span></label>
          <input type="text" id="fc-name" name="name" required autocomplete="name" class="fc-leadform__input" placeholder="Full name" />
          <p id="fc-name-error" class="fc-leadform__error" hidden>Please enter your full name.</p>
        </div>

        <div class="fc-leadform__field">
          <label class="fc-leadform__label" for="fc-email">
            Email address <span class="fc-leadform__required">*</span>
            <span id="fc-email-check" class="fc-leadform__valid-check" hidden>✓</span>
          </label>
          <p class="fc-leadform__helper">No spam. Just your results.</p>
          <input type="email" id="fc-email" name="email" required autocomplete="email" inputmode="email" class="fc-leadform__input" placeholder="you@company.co.uk" />
          <p id="fc-email-error" class="fc-leadform__error" hidden>Please enter a valid email address.</p>
        </div>

        <div class="fc-leadform__field">
          <label class="fc-leadform__label" for="fc-phone">Phone number <span class="fc-leadform__required">*</span></label>
          <p class="fc-leadform__helper">We'll only contact you about your funding options.</p>
          <input type="tel" id="fc-phone" name="phone" required autocomplete="tel" inputmode="tel" class="fc-leadform__input" placeholder="07..." />
          <p id="fc-phone-error" class="fc-leadform__error" hidden>Please enter a valid UK phone number.</p>
        </div>
      </div>

      {/* Bottom nav row */}
      <div class="fc-leadform__nav">
        <button type="button" id="fc-prev-step" class="fc-leadform__back" hidden>
          <span class="fc-leadform__back-arrow">←</span> Back
        </button>
        <span class="fc-leadform__nav-spacer"></span>
        <button type="button" id="fc-next-step" class="fc-leadform__continue" disabled>
          Continue <span class="fc-leadform__continue-arrow">→</span>
        </button>
        <button type="submit" id="fc-submit-step" class="fc-leadform__continue" hidden disabled>
          Check my options <span class="fc-leadform__continue-arrow">→</span>
        </button>
      </div>
    </form>

    <p class="fc-leadform__privacy">
      Your details are secure. See our <a href={config.privacyPath || "/privacy/"}>privacy policy</a>.
    </p>

    {config.trustPills && config.trustPills.length > 0 && (
      <div class="fc-leadform__pills-trust">
        {config.trustPills.map((p, i) => (
          <span>{p}{i < config.trustPills!.length - 1 && <span class="fc-leadform__sep"> · </span>}</span>
        ))}
      </div>
    )}
  </div>
</section>

<script define:vars={{ cfg: clientConfig }}>
  const $ = (id) => document.getElementById(id);

  // --- Attribution (first-touch, sticky for the session) -------------------
  function getOrSetFirstTouch() {
    const KEY = cfg.attributionKey;
    try {
      const existing = sessionStorage.getItem(KEY);
      if (existing) return JSON.parse(existing);
    } catch {}
    const url = new URL(window.location.href);
    const ft = {
      landing_url: window.location.href,
      landing_path: window.location.pathname,
      referrer: document.referrer || null,
      referrer_host: document.referrer ? (new URL(document.referrer).hostname) : null,
      utm_source: url.searchParams.get('utm_source'),
      utm_medium: url.searchParams.get('utm_medium'),
      utm_campaign: url.searchParams.get('utm_campaign'),
      utm_term: url.searchParams.get('utm_term'),
      utm_content: url.searchParams.get('utm_content'),
      gclid: url.searchParams.get('gclid'),
      fbclid: url.searchParams.get('fbclid'),
      msclkid: url.searchParams.get('msclkid'),
      session_started_at: new Date().toISOString(),
    };
    try { sessionStorage.setItem(KEY, JSON.stringify(ft)); } catch {}
    return ft;
  }
  function inferSource(ft) {
    if (ft.utm_source) return ft.utm_source;
    if (ft.gclid) return 'google-ads';
    if (ft.fbclid) return 'facebook-ads';
    if (ft.msclkid) return 'bing-ads';
    if (!ft.referrer_host) return 'direct';
    const h = ft.referrer_host.toLowerCase();
    if (h.includes('google.')) return 'google-organic';
    if (h.includes('bing.')) return 'bing-organic';
    if (h.includes('duckduckgo.')) return 'duckduckgo-organic';
    if (h.includes('chat.openai.') || h.includes('chatgpt.')) return 'chatgpt';
    if (h.includes('perplexity.')) return 'perplexity';
    if (h.includes('claude.') || h.includes('anthropic.')) return 'claude';
    if (h.includes('gemini.') || h.includes('bard.')) return 'gemini';
    if (h.includes(window.location.hostname)) return 'internal';
    return 'referral-' + h;
  }
  const attribution = getOrSetFirstTouch();

  // --- Big-tracking blob ---------------------------------------------------
  const VISITS_KEY = cfg.attributionKey + '__visits';
  function readVisits() { try { return JSON.parse(localStorage.getItem(VISITS_KEY) || '{}'); } catch { return {}; } }
  function writeVisits(v) { try { localStorage.setItem(VISITS_KEY, JSON.stringify(v)); } catch {} }
  const visits = readVisits();
  const nowIso = new Date().toISOString();
  const prevLastVisit = visits.last_visit_at || null;
  const prevCount = Number(visits.visit_count || 0);
  const newVisits = { first_visit_at: visits.first_visit_at || nowIso, last_visit_at: nowIso, visit_count: prevCount + 1 };
  writeVisits(newVisits);
  const isReturning = prevCount > 0;

  const SESSION_PAGES_KEY = cfg.attributionKey + '__session_pages';
  let pagesThisSession = [];
  try { pagesThisSession = JSON.parse(sessionStorage.getItem(SESSION_PAGES_KEY) || '[]'); } catch {}
  if (pagesThisSession[pagesThisSession.length - 1] !== window.location.pathname) {
    pagesThisSession.push(window.location.pathname);
    try { sessionStorage.setItem(SESSION_PAGES_KEY, JSON.stringify(pagesThisSession)); } catch {}
  }

  const ua = navigator.userAgent || '';
  const detectDevice = () => /Mobi|Android|iPhone|iPad|iPod/i.test(ua) ? (/iPad|Tablet/i.test(ua) ? 'tablet' : 'mobile') : 'desktop';
  const detectBrowser = () => {
    if (/Edg\//.test(ua)) return 'edge';
    if (/Chrome\//.test(ua) && !/Edg\//.test(ua)) return 'chrome';
    if (/Safari\//.test(ua) && !/Chrome\//.test(ua)) return 'safari';
    if (/Firefox\//.test(ua)) return 'firefox';
    return 'other';
  };
  const detectOs = () => {
    if (/Windows/i.test(ua)) return 'windows';
    if (/Mac OS X|Macintosh/i.test(ua)) return 'macos';
    if (/Android/i.test(ua)) return 'android';
    if (/iPhone|iPad|iPod/i.test(ua)) return 'ios';
    if (/Linux/i.test(ua)) return 'linux';
    return 'other';
  };
  const clientBlob = {
    device_type: detectDevice(),
    browser: detectBrowser(),
    os: detectOs(),
    viewport_w: window.innerWidth,
    viewport_h: window.innerHeight,
    screen_w: window.screen?.width || null,
    screen_h: window.screen?.height || null,
    language: navigator.language || null,
    languages: (navigator.languages || []).slice(0, 3).join(','),
    timezone: (() => { try { return Intl.DateTimeFormat().resolvedOptions().timeZone; } catch { return null; } })(),
    local_time: new Date().toString(),
    returning_visitor: isReturning ? 'yes' : 'no',
    visit_count: newVisits.visit_count,
    first_visit_at: newVisits.first_visit_at,
    last_visit_at_previous: prevLastVisit,
    pages_this_session: pagesThisSession.join(' -> '),
    pages_this_session_count: pagesThisSession.length,
    page_load_at: nowIso,
  };

  // --- Server-side enrichment ---------------------------------------------
  let serverEnrich = null;
  const ENRICH_KEY = cfg.attributionKey + '__enrich';
  try {
    const cached = sessionStorage.getItem(ENRICH_KEY);
    if (cached) serverEnrich = JSON.parse(cached);
  } catch {}
  (async () => {
    if (serverEnrich || !cfg.enrichPath) return;
    try {
      const r = await fetch(cfg.enrichPath, { method: 'GET' });
      if (!r.ok) return;
      serverEnrich = await r.json();
      try { sessionStorage.setItem(ENRICH_KEY, JSON.stringify(serverEnrich)); } catch {}
    } catch {}
  })();

  const pageLoadAt = Date.now();
  let firstInteractionMs = null;
  const markInteraction = () => { if (firstInteractionMs === null) firstInteractionMs = Date.now() - pageLoadAt; };

  const appliedFromUrl = $('fc-applied-from-url');
  if (appliedFromUrl) appliedFromUrl.value = window.location.href;

  // --- Attribution payload builder ----------------------------------------
  function buildAttributionBlob() {
    return {
      lead_source: inferSource(attribution),
      landing_path: attribution.landing_path || '',
      landing_url: attribution.landing_url || '',
      referrer: attribution.referrer || '(direct)',
      referrer_host: attribution.referrer_host || '',
      utm_source: attribution.utm_source || '',
      utm_medium: attribution.utm_medium || '',
      utm_campaign: attribution.utm_campaign || '',
      utm_term: attribution.utm_term || '',
      utm_content: attribution.utm_content || '',
      gclid: attribution.gclid || '',
      fbclid: attribution.fbclid || '',
      msclkid: attribution.msclkid || '',
      session_started_at: attribution.session_started_at || '',
      ...clientBlob,
      time_to_first_interaction_ms: firstInteractionMs,
      ip: serverEnrich?.ip || '',
      country: serverEnrich?.country || '',
      city: serverEnrich?.city || '',
      region: serverEnrich?.region || '',
      longitude: serverEnrich?.longitude || '',
      latitude: serverEnrich?.latitude || '',
      cf_timezone: serverEnrich?.timezone || '',
      asn: serverEnrich?.asn || '',
      asn_org: serverEnrich?.asn_org || '',
      tls_version: serverEnrich?.tls_version || '',
      bot_score: serverEnrich?.bot_score ?? '',
    };
  }

  // --- Supabase 3-tier writer (preserved from v0.7) -----------------------
  function logToSupabase(data) {
    if (!cfg.supabase) return;
    const attrBlob = buildAttributionBlob();
    const basePayload = { ...data, page_url: window.location.href, applied_from: cfg.appliedFrom, user_agent: navigator.userAgent };
    const fullPayload = {
      ...basePayload,
      source: attrBlob.lead_source,
      landing_path: attrBlob.landing_path,
      referrer: attrBlob.referrer,
      referrer_host: attrBlob.referrer_host,
      utm_source: attrBlob.utm_source,
      utm_medium: attrBlob.utm_medium,
      utm_campaign: attrBlob.utm_campaign,
      utm_term: attrBlob.utm_term,
      utm_content: attrBlob.utm_content,
      gclid: attrBlob.gclid,
      fbclid: attrBlob.fbclid,
      msclkid: attrBlob.msclkid,
      ip: attrBlob.ip,
      country: attrBlob.country,
      device_type: attrBlob.device_type,
      returning_visitor: attrBlob.returning_visitor,
      visit_count: attrBlob.visit_count,
      asn_org: attrBlob.asn_org,
    };
    const post = (body) =>
      fetch(`${cfg.supabase.url}/rest/v1/${cfg.supabase.table}`, {
        method: 'POST',
        headers: { 'apikey': cfg.supabase.anonKey, 'Authorization': `Bearer ${cfg.supabase.anonKey}`, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
        body: JSON.stringify(body),
      });
    const SAFE_COLUMNS = [
      'event_type', 'turnover', 'finance_type',
      'company_name', 'company_number', 'business_postcode',
      'contact_name', 'email', 'phone',
      'page_url', 'applied_from', 'user_agent',
      'source', 'landing_path', 'referrer', 'referrer_host',
      'utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content',
      'gclid', 'fbclid', 'msclkid'
    ];
    const safePayload = {};
    SAFE_COLUMNS.forEach(k => { if (fullPayload[k] !== undefined) safePayload[k] = fullPayload[k]; });
    (async () => {
      try {
        const r1 = await post(fullPayload); if (r1.ok) return;
        const r2 = await post(basePayload); if (r2.ok) return;
        const r3 = await post(safePayload); if (r3.ok) return;
        const err = await r3.text();
        console.error('[fleet-core LeadForm v0.8] Supabase write failed all retries:', r3.status, err);
      } catch (e) {
        console.error('[fleet-core LeadForm v0.8] Supabase write threw:', e);
      }
    })();
  }

  // --- Partial-fill email (fires on company_selected) ---------------------
  let partialEmailSent = false;
  function sendPartialFillEmail(extraNote) {
    if (partialEmailSent || !cfg.partialFillEmail) return;
    partialEmailSent = true;
    const attrBlob = buildAttributionBlob();
    const company = $('fc-company')?.value || '';
    const companyNumber = $('fc-company-number')?.value || '';
    const director = $('fc-director')?.value || $('fc-director-manual-input')?.value || '';
    const trading = $('fc-trading')?.value || '';
    const amount = $('fc-amount')?.value || '';
    const turnover = $('fc-turnover')?.value || '';
    const financeType = $('fc-finance-type')?.value || '';
    try {
      fetch(`https://formsubmit.co/ajax/${cfg.partialFillEmail}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          _subject: `${cfg.emailSubject} - ${company || 'unknown'} (partial fill)`,
          _template: 'table',
          company: company || 'Not entered',
          company_number: companyNumber,
          director, trading_time: trading,
          amount, turnover, finance_type: financeType,
          applied_from: cfg.appliedFrom,
          page_url: window.location.href,
          note: extraNote || 'Company selected but full submit not yet received.',
          ...attrBlob,
        }),
      }).catch(() => {});
    } catch {}
  }

  // --- gtag + custom-event hook -------------------------------------------
  function trackEvent(name, params) {
    if (typeof window.gtag === 'function') window.gtag('event', name, params || {});
    window.dispatchEvent(new CustomEvent('fc-leadform', { detail: { event: name, ...params } }));
  }
  trackEvent('form_view', { applied_from: cfg.appliedFrom });

  // --- Inline error helpers -----------------------------------------------
  function showError(fieldId) {
    const err = $(fieldId + '-error');
    if (err) err.removeAttribute('hidden');
    const input = $(fieldId);
    if (input) input.style.borderColor = '#fca5a5';
  }
  function clearError(fieldId) {
    const err = $(fieldId + '-error');
    if (err) err.setAttribute('hidden', '');
    const input = $(fieldId);
    if (input) input.style.borderColor = '';
  }

  // --- £ + chip-preset bindings -------------------------------------------
  const formatGBP = (raw) => {
    const num = String(raw).replace(/[^0-9]/g, '');
    if (!num) return '';
    return Number(num).toLocaleString('en-GB');
  };
  function bindCurrencyChipInput(inputId) {
    const input = $(inputId);
    if (!input) return;
    if (input.value) input.value = formatGBP(input.value);
    input.addEventListener('input', () => {
      markInteraction();
      input.value = formatGBP(input.value);
      validateCurrentStep();
      document.querySelectorAll(`[data-target="${inputId}"]`).forEach(c => c.classList.remove('fc-leadform__chip--selected'));
      clearError(inputId);
    });
    document.querySelectorAll(`[data-target="${inputId}"]`).forEach(chip => {
      chip.addEventListener('click', () => {
        markInteraction();
        const v = chip.getAttribute('data-value');
        input.value = formatGBP(v);
        document.querySelectorAll(`[data-target="${inputId}"]`).forEach(c => c.classList.remove('fc-leadform__chip--selected'));
        chip.classList.add('fc-leadform__chip--selected');
        clearError(inputId);
        validateCurrentStep();
        trackEvent('chip_selected', { input: inputId, value: v });
      });
    });
  }
  bindCurrencyChipInput('fc-amount');
  bindCurrencyChipInput('fc-turnover');

  // --- Pill group bindings (finance, trading) -----------------------------
  function bindPillGroup(groupName, hiddenId) {
    const group = document.querySelector(`[data-pill-group="${groupName}"]`);
    if (!group) return;
    const hidden = $(hiddenId);
    const pills = group.querySelectorAll('.fc-leadform__pill');
    pills.forEach(p => {
      if (p.getAttribute('data-default') === '1') {
        p.classList.add('fc-leadform__pill--selected');
        if (hidden) hidden.value = p.getAttribute('data-value') || '';
      }
      p.addEventListener('click', () => {
        markInteraction();
        pills.forEach(o => o.classList.remove('fc-leadform__pill--selected'));
        p.classList.add('fc-leadform__pill--selected');
        if (hidden) hidden.value = p.getAttribute('data-value') || '';
        clearError(hiddenId);
        validateCurrentStep();
        trackEvent('pill_selected', { group: groupName, value: hidden ? hidden.value : null });
      });
    });
  }
  bindPillGroup('finance', 'fc-finance-type');
  bindPillGroup('trading', 'fc-trading');

  // --- Progressive disclosure on turnover ---------------------------------
  $('fc-turnover')?.addEventListener('blur', () => {
    if (String($('fc-turnover').value).replace(/[^0-9]/g, '').length > 0) {
      $('fc-turnover-followup')?.removeAttribute('hidden');
    }
  });
  document.querySelectorAll('input[name="turnover_higher"]').forEach(r => {
    r.addEventListener('change', (e) => {
      if (e.target.value === 'yes') {
        $('fc-monthly-revenue-field')?.removeAttribute('hidden');
      } else {
        $('fc-monthly-revenue-field')?.setAttribute('hidden', '');
      }
    });
  });
  $('fc-monthly-revenue')?.addEventListener('input', (e) => {
    e.target.value = formatGBP(e.target.value);
  });

  // --- Companies House autocomplete ---------------------------------------
  let chTimer;
  const companyInput = $('fc-company');
  const manualMode = $('fc-manual-mode');
  if (companyInput && cfg.companiesHouseProxyPath) {
    companyInput.addEventListener('input', () => {
      markInteraction();
      clearTimeout(chTimer);
      clearError('fc-company');
      const q = companyInput.value.trim();
      if (q.length < 3) { $('fc-ch-results')?.setAttribute('hidden', ''); return; }
      chTimer = setTimeout(async () => {
        try {
          const res = await fetch(`${cfg.companiesHouseProxyPath}?q=${encodeURIComponent(q)}`);
          if (!res.ok) return;
          const data = await res.json();
          const items = (data.items || []).slice(0, 8);
          const truncate = (s, n) => (s && s.length > n) ? s.slice(0, n - 1).replace(/[,\s]+$/, '') + '…' : (s || '');
          const html = items.map(item => {
            const status = (item.company_status || '').toLowerCase();
            const statusClass = status === 'active' ? 'fc-leadform__ch-pill--active' : status === 'dissolved' ? 'fc-leadform__ch-pill--dissolved' : 'fc-leadform__ch-pill--other';
            const addr = truncate(item.address_snippet || '', 64);
            return `
              <div class="fc-leadform__ch-item" tabindex="0"
                data-name="${item.title || ''}"
                data-number="${item.company_number || ''}"
                data-status="${status}"
                data-postcode="${(item.address && item.address.postal_code) || ''}">
                <div class="fc-leadform__ch-row1">
                  <span class="fc-leadform__ch-name">${item.title || ''}</span>
                  ${status ? `<span class="fc-leadform__ch-pill ${statusClass}">${status}</span>` : ''}
                </div>
                <div class="fc-leadform__ch-row2">
                  <span class="fc-leadform__ch-number">${item.company_number || ''}</span>${addr ? `<span class="fc-leadform__ch-dot"> · </span><span class="fc-leadform__ch-addr">${addr}</span>` : ''}
                </div>
              </div>`;
          }).join('');
          const box = $('fc-ch-results');
          if (!box) return;
          box.innerHTML = html;
          box.removeAttribute('hidden');
          box.querySelectorAll('.fc-leadform__ch-item').forEach(el => {
            el.addEventListener('click', () => selectCompany(el));
            el.addEventListener('keydown', (e) => { if (e.key === 'Enter') selectCompany(el); });
          });
        } catch {}
      }, 250);
    });
  }
  function selectCompany(el) {
    const name = el.getAttribute('data-name');
    const number = el.getAttribute('data-number');
    const status = el.getAttribute('data-status');
    const postcode = el.getAttribute('data-postcode');
    companyInput.value = name;
    $('fc-company-number').value = number;
    $('fc-company-status').value = status;
    $('fc-business-postcode').value = postcode;
    $('fc-ch-info').textContent = `${name} · ${number}${postcode ? ' · ' + postcode : ''}`;
    $('fc-ch-info').removeAttribute('hidden');
    $('fc-ch-results').setAttribute('hidden', '');
    clearError('fc-company');
    loadDirectors(number);
    sendPartialFillEmail(`Company selected: ${name} (${number}). Director auto-load in progress.`);
    trackEvent('company_selected', { company: name, company_number: number });
    validateCurrentStep();
  }

  // --- "Can't find your business?" → manual mode --------------------------
  const cantFindBtn = $('fc-cant-find');
  cantFindBtn?.addEventListener('click', () => {
    if (!manualMode) return;
    manualMode.removeAttribute('hidden');
    cantFindBtn.style.display = 'none';
    $('fc-ch-results')?.setAttribute('hidden', '');
    $('fc-business-postcode-visible')?.focus();
    trackEvent('manual_mode_opened');
  });
  $('fc-back-to-autocomplete')?.addEventListener('click', () => {
    if (!manualMode) return;
    manualMode.setAttribute('hidden', '');
    if (cantFindBtn) cantFindBtn.style.display = '';
    $('fc-business-postcode-visible').value = '';
    companyInput?.focus();
  });
  $('fc-business-postcode-visible')?.addEventListener('input', validateCurrentStep);

  // --- Companies House officers fetch (director dropdown) -----------------
  async function loadDirectors(number) {
    if (!cfg.companiesHouseOfficersPath) return;
    const field = $('fc-director-field');
    const select = $('fc-director');
    const manualWrap = $('fc-director-manual');
    const manualInput = $('fc-director-manual-input');
    field?.removeAttribute('hidden');
    manualWrap?.setAttribute('hidden', '');
    if (manualInput) manualInput.value = '';
    select?.removeAttribute('hidden');
    if (select) {
      select.innerHTML = '<option value="">Loading directors…</option>';
      select.disabled = true;
    }
    try {
      const res = await fetch(`${cfg.companiesHouseOfficersPath}?number=${encodeURIComponent(number)}`);
      if (!res.ok) throw new Error('officers fetch failed');
      const data = await res.json();
      const officers = data.officers || [];
      if (officers.length === 0) {
        select?.setAttribute('hidden', '');
        manualWrap?.removeAttribute('hidden');
        manualInput?.focus();
      } else if (select) {
        select.innerHTML = '<option value="">Choose director…</option>' +
          officers.map(o => `<option value="${o.name.replace(/"/g, '&quot;')}">${o.name}</option>`).join('');
        select.disabled = false;
      }
    } catch {
      select?.setAttribute('hidden', '');
      manualWrap?.removeAttribute('hidden');
    }
    validateCurrentStep();
  }
  $('fc-director-manual-toggle')?.addEventListener('click', () => {
    $('fc-director')?.setAttribute('hidden', '');
    const s = $('fc-director'); if (s) s.value = '';
    $('fc-director-manual')?.removeAttribute('hidden');
    $('fc-director-manual-input')?.focus();
    validateCurrentStep();
  });
  $('fc-director-back-to-list')?.addEventListener('click', () => {
    $('fc-director-manual')?.setAttribute('hidden', '');
    const m = $('fc-director-manual-input'); if (m) m.value = '';
    $('fc-director')?.removeAttribute('hidden');
    validateCurrentStep();
  });
  $('fc-director')?.addEventListener('change', validateCurrentStep);
  $('fc-director-manual-input')?.addEventListener('input', validateCurrentStep);

  // --- Inline email validation --------------------------------------------
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  $('fc-email')?.addEventListener('input', () => {
    markInteraction();
    const v = $('fc-email').value.trim();
    const valid = EMAIL_RE.test(v);
    const check = $('fc-email-check');
    if (valid) check?.removeAttribute('hidden'); else check?.setAttribute('hidden', '');
    if (valid) clearError('fc-email');
    validateCurrentStep();
  });
  $('fc-phone')?.addEventListener('input', () => { markInteraction(); validateCurrentStep(); });
  $('fc-name')?.addEventListener('input', () => { markInteraction(); validateCurrentStep(); });

  // --- Step validation ----------------------------------------------------
  let currentStep = 1;
  function isStep1Valid() {
    const companyNumber = $('fc-company-number')?.value;
    const postcodeVisible = $('fc-business-postcode-visible')?.value?.trim();
    const usingManual = !manualMode?.hasAttribute('hidden') && manualMode?.offsetParent !== null;
    const companyOk = usingManual ? Boolean(postcodeVisible) : Boolean(companyNumber && companyInput?.value && companyInput.value.length >= 2);
    // Director only required when shown (company picked from CH)
    const directorFieldHidden = $('fc-director-field')?.hasAttribute('hidden');
    const directorOk = directorFieldHidden ? true : Boolean($('fc-director')?.value || ($('fc-director-manual-input')?.value || '').trim().length >= 2);
    return Boolean(
      companyOk && directorOk &&
      $('fc-trading')?.value &&
      $('fc-amount')?.value &&
      $('fc-turnover')?.value &&
      $('fc-finance-type')?.value
    );
  }
  function isStep2Valid() {
    const name = $('fc-name')?.value?.trim() || '';
    const email = $('fc-email')?.value?.trim() || '';
    const phone = ($('fc-phone')?.value || '').replace(/[^0-9+]/g, '');
    return Boolean(name.length >= 2 && EMAIL_RE.test(email) && phone.length >= 10);
  }
  function validateCurrentStep() {
    if (currentStep === 1) {
      const btn = $('fc-next-step'); if (btn) btn.disabled = !isStep1Valid();
    } else {
      const btn = $('fc-submit-step'); if (btn) btn.disabled = !isStep2Valid();
    }
  }

  // --- Step 1 → 2 transition ----------------------------------------------
  $('fc-next-step')?.addEventListener('click', () => {
    markInteraction();
    if (!isStep1Valid()) return;
    // Update progress
    const segs = document.querySelectorAll('.fc-leadform__progress-seg');
    segs[0]?.classList.remove('fc-leadform__progress-seg--active');
    segs[0]?.classList.add('fc-leadform__progress-seg--complete');
    segs[1]?.classList.add('fc-leadform__progress-seg--active');

    const company = companyInput?.value;
    const director = $('fc-director')?.value || $('fc-director-manual-input')?.value || '';
    const trading = document.querySelector('[data-pill-group="trading"] .fc-leadform__pill--selected')?.textContent || '';
    const amount = $('fc-amount')?.value;
    const turnover = $('fc-turnover')?.value;
    const finance = document.querySelector('[data-pill-group="finance"] .fc-leadform__pill--selected')?.textContent || '';
    const recap = $('fc-step2-recap');
    if (recap) recap.textContent = `Matching ${company}${director ? ' · ' + director : ''} · ${trading} · £${amount} · £${turnover}/mo · ${finance}`;

    $('fc-step-1').setAttribute('hidden', '');
    $('fc-step-2').removeAttribute('hidden');
    $('fc-next-step').setAttribute('hidden', '');
    $('fc-submit-step').removeAttribute('hidden');
    $('fc-prev-step').removeAttribute('hidden');
    currentStep = 2;
    validateCurrentStep();
    $('fc-name')?.focus();

    trackEvent('form_step_2', { company, director, trading_time: $('fc-trading')?.value, amount, turnover, finance_type: $('fc-finance-type')?.value, applied_from: cfg.appliedFrom });
    logToSupabase({
      event_type: 'step_1_complete',
      turnover, finance_type: $('fc-finance-type')?.value,
      company_name: company,
      company_number: $('fc-company-number')?.value || null,
      business_postcode: $('fc-business-postcode')?.value || null,
    });
    sendPartialFillEmail('Step 1 complete, contact details not yet entered.');
  });

  $('fc-prev-step')?.addEventListener('click', () => {
    const segs = document.querySelectorAll('.fc-leadform__progress-seg');
    segs[0]?.classList.add('fc-leadform__progress-seg--active');
    segs[0]?.classList.remove('fc-leadform__progress-seg--complete');
    segs[1]?.classList.remove('fc-leadform__progress-seg--active');

    $('fc-step-2').setAttribute('hidden', '');
    $('fc-step-1').removeAttribute('hidden');
    $('fc-submit-step').setAttribute('hidden', '');
    $('fc-next-step').removeAttribute('hidden');
    $('fc-prev-step').setAttribute('hidden', '');
    currentStep = 1;
    validateCurrentStep();
    trackEvent('form_step_back');
  });

  // --- Submit handler -----------------------------------------------------
  const UK_POSTCODE_RE = /^[A-Z]{1,2}\d[A-Z\d]?\s*\d[A-Z]{2}$/i;
  let abandonTimer;

  $('fc-lead-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!isStep2Valid()) {
      if (!EMAIL_RE.test($('fc-email').value)) showError('fc-email');
      const phone = ($('fc-phone').value || '').replace(/[^0-9+]/g, '');
      if (phone.length < 10) showError('fc-phone');
      const name = $('fc-name').value.trim();
      if (name.length < 2) showError('fc-name');
      return;
    }
    const form = e.target;

    // Postcode check — if using manual mode, validate the visible field
    const postcodeHidden = $('fc-business-postcode');
    const postcodeVisible = $('fc-business-postcode-visible');
    const usingManual = !manualMode?.hasAttribute('hidden') && manualMode?.offsetParent !== null;
    if (usingManual) {
      const effective = (postcodeVisible?.value || '').trim();
      if (!effective || !UK_POSTCODE_RE.test(effective)) {
        showError('fc-business-postcode-visible');
        postcodeVisible?.focus();
        return;
      }
      if (postcodeHidden) postcodeHidden.value = effective;
    }

    const fd = new FormData(form);
    const data = Object.fromEntries(fd);
    data._subject = cfg.emailSubject;
    data._template = 'table';
    if (cfg.partialFillEmail) {
      data._autoresponse = `Thanks. We've received your application and will route it to UK lenders most likely to approve based on your profile and ticket size. Expect to hear from a matched broker within 24 hours.\n\nIf you didn't submit this, ignore this email.`;
    }
    data.page_url = window.location.href;
    Object.assign(data, buildAttributionBlob());

    const submitBtn = $('fc-submit-step');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.innerHTML = 'Sending…'; }

    try {
      const res = await fetch(cfg.submitEndpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();
      if (result.success) {
        trackEvent('form_submit_success', { company: data.company, amount: data.amount, turnover: data.turnover, finance_type: data.finance_type, applied_from: cfg.appliedFrom });
        clearTimeout(abandonTimer);
        logToSupabase({
          event_type: 'form_submit',
          turnover: data.turnover,
          finance_type: data.finance_type,
          company_name: data.company,
          company_number: data.company_number || null,
          business_postcode: data.business_postcode || null,
          contact_name: data.name,
          email: data.email,
          phone: data.phone,
        });
        form.innerHTML = cfg.successHTML;
      } else {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = 'Check my options <span class="fc-leadform__continue-arrow">→</span>'; }
        trackEvent('form_submit_error');
      }
    } catch {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = 'Check my options <span class="fc-leadform__continue-arrow">→</span>'; }
      trackEvent('form_submit_error');
    }
  });

  // --- 5-min step-2 abandon -----------------------------------------------
  const observer = new MutationObserver(() => {
    const step2 = $('fc-step-2');
    if (step2 && !step2.hasAttribute('hidden')) {
      abandonTimer = setTimeout(() => {
        const company = $('fc-company')?.value;
        const companyNumber = $('fc-company-number')?.value;
        const director = $('fc-director')?.value || $('fc-director-manual-input')?.value || '';
        const trading = $('fc-trading')?.value;
        const name = $('fc-name')?.value;
        const email = $('fc-email')?.value;
        const phone = $('fc-phone')?.value;
        const amount = $('fc-amount')?.value;
        const turnover = $('fc-turnover')?.value;
        const financeType = $('fc-finance-type')?.value;
        trackEvent('form_abandon_step2', { partial_data: (name || email) ? 'started' : 'none', has_name: name ? 'yes' : 'no', has_email: email ? 'yes' : 'no', applied_from: cfg.appliedFrom });
        logToSupabase({
          event_type: 'form_abandon',
          turnover: turnover || null,
          finance_type: financeType || null,
          company_name: company || null,
          company_number: companyNumber || null,
          contact_name: name || null,
          email: email || null,
          phone: phone || null,
        });
        if (cfg.partialFillEmail) {
          const attrBlob = buildAttributionBlob();
          try {
            fetch(`https://formsubmit.co/ajax/${cfg.partialFillEmail}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({
                _subject: `${cfg.emailSubject} - ABANDONED at step 2 (${company || 'unknown'})`,
                _template: 'table',
                company: company || 'Not entered',
                company_number: companyNumber || '',
                director,
                trading_time: trading || '',
                amount: amount || '',
                turnover: turnover || '',
                finance_type: financeType || '',
                contact_name: name || '',
                email: email || '',
                phone: phone || '',
                applied_from: cfg.appliedFrom,
                page_url: window.location.href,
                note: '5 minutes on step 2 with no submit.',
                ...attrBlob,
              }),
            }).catch(() => {});
          } catch {}
        }
      }, 300000);
    } else {
      clearTimeout(abandonTimer);
    }
  });
  const step2El = $('fc-step-2');
  if (step2El) observer.observe(step2El, { attributes: true, attributeFilter: ['hidden'] });

  // initial validate
  validateCurrentStep();
</script>

<style is:global>
  /* CARD (light, on cream backdrop — host sets surrounding bg) */
  .fc-leadform {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 24px 60px -20px rgba(22, 40, 87, 0.18), 0 8px 16px -8px rgba(0, 0, 0, 0.05);
    padding: 1.75rem 1.75rem 1.5rem;
    max-width: 32rem;
    margin: 0 auto;
    width: 100%;
    border: 1px solid rgba(22, 40, 87, 0.08);
