    max-height: 12rem; overflow-y: auto; z-index: 10;
    box-shadow: var(--fc-shadow-lg);
  }
  .fc-leadform__ch-results[hidden] { display: none; }
  .fc-leadform__ch-item {
    padding: var(--fc-sp-3) var(--fc-sp-4);
    border-bottom: 1px solid var(--fc-border);
    cursor: pointer; color: var(--fc-text);
  }
  .fc-leadform__ch-item:hover { background: var(--fc-bg-muted); }
  .fc-leadform__ch-item:last-child { border-bottom: 0; }
  .fc-leadform__ch-name { font-size: var(--fc-fs-sm); font-weight: 500; color: var(--fc-text); }
  .fc-leadform__ch-meta { font-size: var(--fc-fs-xs); color: var(--fc-text-subtle); }
  .fc-leadform__ch-info {
    font-size: var(--fc-fs-xs);
    color: rgba(255, 255, 255, 0.7);
    margin: calc(-1 * var(--fc-sp-2)) 0 0;
  }
  .fc-leadform__ch-info[hidden] { display: none; }

  .fc-leadform__cant-find {
    background: transparent; border: 0;
    color: rgba(255, 255, 255, 0.65);
    font-size: var(--fc-fs-xs);
    text-decoration: underline;
    cursor: pointer;
    margin: calc(-1 * var(--fc-sp-2)) 0 0;
    text-align: left;
    padding: 0;
  }
  .fc-leadform__cant-find:hover { color: white; }
  .fc-leadform__manual {
    background: rgba(255, 255, 255, 0.06);
    border-radius: var(--fc-radius);
    padding: var(--fc-sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--fc-sp-3);
  }
  .fc-leadform__manual[hidden] { display: none; }
  .fc-leadform__manual-info {
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--fc-fs-xs);
    margin: 0;
    line-height: var(--fc-leading-snug);
  }
  .fc-leadform__manual-back {
    background: transparent; border: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: var(--fc-fs-xs);
    text-decoration: underline;
    cursor: pointer; padding: 0;
    text-align: left;
  }
  .fc-leadform__manual-back:hover { color: white; }

  /* Tile grids — boxes for amount, turnover, finance-type */
  .fc-leadform__tile-group {
    border: 0; padding: 0; margin: 0;
    display: flex; flex-direction: column;
    gap: var(--fc-sp-2);
  }
  .fc-leadform__tiles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--fc-sp-2);
  }
  @media (min-width: 480px) {
    .fc-leadform__tiles { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 768px) {
    .fc-leadform__tiles { grid-template-columns: repeat(5, 1fr); }
    .fc-leadform__tiles--wide { grid-template-columns: repeat(2, 1fr); }
  }
  .fc-leadform__tile {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--fc-radius);
    color: white;
    padding: var(--fc-sp-3) var(--fc-sp-2);
    font-family: var(--fc-font-body);
    font-size: var(--fc-fs-sm);
    cursor: pointer;
    transition: all 150ms ease;
    text-align: center;
    display: flex; flex-direction: column;
    gap: 2px;
    min-height: 56px;
    align-items: center; justify-content: center;
  }
  .fc-leadform__tile:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.32);
  }
  .fc-leadform__tile--selected {
    background: var(--fc-accent, #ec4f31);
    border-color: var(--fc-accent, #ec4f31);
    color: white;
    font-weight: 600;
  }
  .fc-leadform__tile-label { font-size: var(--fc-fs-sm); }
  .fc-leadform__tile-desc {
    font-size: var(--fc-fs-xs);
    color: rgba(255, 255, 255, 0.6);
    margin-top: 1px;
  }
  .fc-leadform__tile--selected .fc-leadform__tile-desc {
    color: rgba(255, 255, 255, 0.85);
  }

  .fc-leadform__step2-recap {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--fc-fs-xs);
    margin: 0 0 var(--fc-sp-3);
    padding: var(--fc-sp-2) var(--fc-sp-3);
    background: rgba(255, 255, 255, 0.06);
    border-radius: var(--fc-radius);
    text-align: center;
  }

  .fc-leadform__error {
    font-size: var(--fc-fs-xs);
    color: #fca5a5;
    margin: calc(-1 * var(--fc-sp-2)) 0 0;
  }
  .fc-leadform__error[hidden] { display: none; }
  .fc-leadform__cta {
    width: 100%;
    margin-top: var(--fc-sp-2);
    padding: var(--fc-sp-3) var(--fc-sp-6);
    font-size: var(--fc-fs-base);
  }
  .fc-leadform__back {
