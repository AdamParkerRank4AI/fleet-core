    border: 1px solid transparent;
  }
  .fc-leadform__input:focus { outline: 2px solid var(--fc-accent); outline-offset: 2px; }
  .fc-leadform__company-wrap { position: relative; }
  .fc-leadform__ch-results {
    position: absolute; top: 100%; left: 0; right: 0;
    background: white;
    border: 1px solid var(--fc-border);
