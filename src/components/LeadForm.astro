    .fc-leadform { padding: var(--fc-sp-16) var(--fc-sp-12); }
  }
  .fc-leadform__inner { max-width: 32rem; margin: 0 auto; }
  .fc-leadform__heading {
    font-family: var(--fc-font-display);
    font-size: var(--fc-fs-2xl);
