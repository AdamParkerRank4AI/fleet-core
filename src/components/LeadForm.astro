    letter-spacing: 0.06em;
    font-weight: 600;
    margin-bottom: var(--fc-sp-4);
  }
  .fc-leadform__progress-sep { color: rgba(255, 255, 255, 0.3); }
  .fc-leadform__form { display: flex; flex-direction: column; }
  .fc-leadform__step { display: flex; flex-direction: column; gap: var(--fc-sp-4); }
  .fc-leadform__step[hidden] { display: none; }
