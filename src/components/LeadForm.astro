---
/**
 * LeadForm — fleet-canonical lead capture form.
 *
 * Lifted from MarketInvoice's working production component (350 pages,
 * captures real leads). Adds:
 *   - Site-configurable finance types, industries, turnover bands
 *   - Site-configurable submit endpoint + Supabase table
 *   - Explicit `applied_from` field stamped on every lead so attribution
 *     captures which page funnelled the user in
 *
 * Two-step form:
 *   Step 1 — turnover, industry, finance type
 *   Step 2 — company (Companies House autocomplete), contact name, email, phone
 *
 * Business postcode is captured automatically from Companies House
 * `address.postal_code` when the user picks a company from autocomplete. If
 * the user submits without picking (or CH had no postcode), a fallback
 * postcode input is revealed inline and required before the form submits.
 *
 * Tracks every meaningful event:
 *   form_view, company_selected, form_step_2, form_step_back,
 *   form_abandon_step2 (5 min after entering step 2 with no submit),
 *   form_submit_success / form_submit_error
 *
 * Logs to Supabase at: step_1_complete, form_submit, form_abandon.
 * Sends partial-fill email notification when step 1 completes.
 *
 * First-touch attribution stored in sessionStorage (sticky across pages):
 * UTM params, gclid/fbclid/msclkid, referrer + inferred source
 * (google-organic, chatgpt, perplexity, claude, gemini, etc.)
 */

interface FinanceOption {
  value: string;
  label: string;
}

export interface LeadFormConfig {
  submitEndpoint: string;
  partialFillEmail?: string;
  emailSubject?: string;
  supabase?: { url: string; anonKey: string; table: string };
  /**
   * Path to the same-origin Companies House search proxy. The host site MUST
   * provide a Cloudflare Pages Function at this path that proxies to
   * api.company-information.service.gov.uk with the API key in `context.env`.
   * Default: `/api/companies-house/search`. Pass `null` to disable autocomplete.
   */
  companiesHouseProxyPath?: string | null;
  industries: FinanceOption[];
  financeTypes: FinanceOption[];
  turnoverBands: FinanceOption[];
  trustPills?: string[];
  successHTML?: string;
  privacyPath?: string;
  attributionKey?: string;
}

interface Props {
  config: LeadFormConfig;
  heading?: string;
  subheading?: string;
  /** Single line of broker-handoff disclosure shown under the heading. */
  brokerDisclosure?: string;
  appliedFrom?: string;
  /** Pre-fill the finance-type dropdown — pass via URL param ?finance_type= */
  defaultFinanceType?: string;
  /** Pre-fill the industry dropdown — pass via URL param ?industry= */
  defaultIndustry?: string;
  /** Pre-fill the turnover dropdown — pass via URL param ?turnover= */
  defaultTurnover?: string;
  /** The lender slug a sister-site review routed from. Stamped on the lead but not visible. */
  lenderContext?: string;
}

const {
  config,
  heading = "Get matched with the right lender",
  subheading = "Two minutes. No obligation. Soft search only.",
  brokerDisclosure,
  appliedFrom,
  defaultFinanceType,
  defaultIndustry,
  defaultTurnover,
  lenderContext,
} = Astro.props;

const resolvedAppliedFrom = appliedFrom || Astro.url.pathname;

const clientConfig = {
  submitEndpoint: config.submitEndpoint,
  partialFillEmail: config.partialFillEmail || null,
  emailSubject: config.emailSubject || "New lead",
  supabase: config.supabase || null,
  // Companies House proxy: same-origin Pages Function. `null` disables autocomplete.
  // Default `/api/companies-house/search` — host site must ship that function.
  companiesHouseProxyPath:
    config.companiesHouseProxyPath === null
      ? null
      : config.companiesHouseProxyPath || "/api/companies-house/search",
  attributionKey: config.attributionKey || "fc_first_touch",
  appliedFrom: resolvedAppliedFrom,
  successHTML:
    config.successHTML ||
    '<div class="text-center py-8"><h3 class="text-2xl font-bold mb-2">Thank you</h3><p style="color: rgba(255,255,255,0.7);">We\'ll be in touch within 24 hours.</p></div>',
  privacyPath: config.privacyPath || "/privacy/",
};
---

<section class="fc-leadform" data-fc-leadform>
  <div class="fc-leadform__inner">
    <h2 class="fc-leadform__heading">{heading}</h2>
    {subheading && <p class="fc-leadform__sub">{subheading}</p>}
    {brokerDisclosure && <p class="fc-leadform__disclosure">{brokerDisclosure}</p>}

    <div class="fc-leadform__progress" aria-live="polite">
      <span>Step <span id="fc-step-num">1</span> of 2</span>
      <span class="fc-leadform__progress-sep"> · </span>
      <span>Takes 2 minutes</span>
    </div>

    <form id="fc-lead-form" class="fc-leadform__form" novalidate>
      <input type="hidden" name="applied_from" value={resolvedAppliedFrom} />
      <input type="hidden" name="applied_from_url" id="fc-applied-from-url" />
      {lenderContext && <input type="hidden" name="lender_context" value={lenderContext} />}

      {/* Step 1: 3 dropdowns only (no typing wall, low friction) */}
      <div id="fc-step-1" class="fc-leadform__step">
        <label class="fc-leadform__label" for="fc-turnover">Annual turnover</label>
        <select id="fc-turnover" name="turnover" required class="fc-leadform__input">
          <option value="">Select</option>
          {config.turnoverBands.map(b => (
            <option value={b.value} selected={defaultTurnover === b.value}>{b.label}</option>
          ))}
        </select>
        <p id="fc-turnover-error" class="fc-leadform__error" hidden>Please select your turnover.</p>

        <label class="fc-leadform__label" for="fc-industry">Industry or sector</label>
        <select id="fc-industry" name="industry" required class="fc-leadform__input">
          <option value="">Select</option>
          {config.industries.map(i => (
            <option value={i.value} selected={defaultIndustry === i.value}>{i.label}</option>
          ))}
        </select>
        <p id="fc-industry-error" class="fc-leadform__error" hidden>Please select your sector.</p>

        <label class="fc-leadform__label" for="fc-finance-type">Type of finance you need</label>
        <select id="fc-finance-type" name="finance_type" required class="fc-leadform__input">
          <option value="">Select</option>
          {config.financeTypes.map(f => (
            <option value={f.value} selected={defaultFinanceType === f.value}>{f.label}</option>
          ))}
        </select>
        <p id="fc-finance-type-error" class="fc-leadform__error" hidden>Please select a finance type.</p>

        <button type="button" id="fc-next-step" class="fc-btn-primary fc-leadform__cta">Next →</button>
      </div>

      {/* Step 2: company + contact (identity commitment moved here) */}
      <div id="fc-step-2" class="fc-leadform__step" hidden>
        <label class="fc-leadform__label" for="fc-company">
          Company name <span class="fc-leadform__required">*</span>
        </label>
        <div class="fc-leadform__company-wrap">
          <input type="text" id="fc-company" name="company" required autocomplete="organization"
            class="fc-leadform__input"
            placeholder="Start typing your registered company name…" />
          <div id="fc-ch-results" class="fc-leadform__ch-results" hidden></div>
        </div>
        <input type="hidden" id="fc-company-number" name="company_number" />
        <input type="hidden" id="fc-company-status" name="company_status" />
        {/* business_postcode is captured automatically when the user picks a
            company from Companies House autocomplete (CH returns address.postal_code).
            If autocomplete is skipped or returns no postcode, this field is revealed
            on submit so the user can add it manually. */}
        <input type="hidden" id="fc-business-postcode" name="business_postcode" />
        <p id="fc-ch-info" class="fc-leadform__ch-info" hidden></p>
        <p id="fc-company-error" class="fc-leadform__error" hidden>Please enter your company name.</p>

        <div id="fc-postcode-fallback" class="fc-leadform__postcode-fallback" hidden>
          <label class="fc-leadform__label" for="fc-business-postcode-visible">
            Business postcode <span class="fc-leadform__required">*</span>
          </label>
          <input type="text" id="fc-business-postcode-visible" autocomplete="postal-code"
            class="fc-leadform__input" placeholder="e.g. SW1A 1AA"
            inputmode="text" maxlength="10" />
          <p id="fc-business-postcode-visible-error" class="fc-leadform__error" hidden>Please enter a valid UK postcode.</p>
          <p class="fc-leadform__ch-info">We couldn't find your registered address from Companies House. Please add your business postcode.</p>
        </div>

        <label class="fc-leadform__label" for="fc-name">Your name <span class="fc-leadform__required">*</span></label>
        <input type="text" id="fc-name" name="name" required autocomplete="name" class="fc-leadform__input" placeholder="Full name" />
        <p id="fc-name-error" class="fc-leadform__error" hidden>Please enter your full name.</p>

        <label class="fc-leadform__label" for="fc-email">Work email <span class="fc-leadform__required">*</span></label>
        <input type="email" id="fc-email" name="email" required autocomplete="email" inputmode="email" class="fc-leadform__input" placeholder="you@company.co.uk" />
        <p id="fc-email-error" class="fc-leadform__error" hidden>Please enter a valid email address.</p>

        <label class="fc-leadform__label" for="fc-phone">Phone <span class="fc-leadform__required">*</span></label>
        <input type="tel" id="fc-phone" name="phone" required autocomplete="tel" inputmode="tel" class="fc-leadform__input" placeholder="07xxx xxx xxx" />
        <p id="fc-phone-error" class="fc-leadform__error" hidden>Please enter a valid UK phone number.</p>

        <button type="submit" class="fc-btn-primary fc-leadform__cta">See my matches →</button>
        <button type="button" id="fc-prev-step" class="fc-leadform__back">← Back</button>
      </div>
    </form>

    <p class="fc-leadform__privacy">
      Your details are secure. See our <a href={config.privacyPath || "/privacy/"}>privacy policy</a>.
    </p>

    {config.trustPills && config.trustPills.length > 0 && (
      <div class="fc-leadform__pills">
        {config.trustPills.map((p, i) => (
          <span>{p}{i < config.trustPills!.length - 1 && <span class="fc-leadform__sep"> · </span>}</span>
        ))}
      </div>
    )}
  </div>
</section>

<script define:vars={{ cfg: clientConfig }}>
  function getOrSetFirstTouch() {
    const KEY = cfg.attributionKey;
    try {
      const existing = sessionStorage.getItem(KEY);
      if (existing) return JSON.parse(existing);
    } catch {}
    const url = new URL(window.location.href);
    const ft = {
      landing_url: window.location.href,
      landing_path: window.location.pathname,
      referrer: document.referrer || null,
      referrer_host: document.referrer ? (new URL(document.referrer).hostname) : null,
      utm_source: url.searchParams.get('utm_source'),
      utm_medium: url.searchParams.get('utm_medium'),
      utm_campaign: url.searchParams.get('utm_campaign'),
      utm_term: url.searchParams.get('utm_term'),
      utm_content: url.searchParams.get('utm_content'),
      gclid: url.searchParams.get('gclid'),
      fbclid: url.searchParams.get('fbclid'),
      msclkid: url.searchParams.get('msclkid'),
      session_started_at: new Date().toISOString(),
    };
    try { sessionStorage.setItem(KEY, JSON.stringify(ft)); } catch {}
    return ft;
  }

  function inferSource(ft) {
    if (ft.utm_source) return ft.utm_source;
    if (ft.gclid) return 'google-ads';
    if (ft.fbclid) return 'facebook-ads';
    if (ft.msclkid) return 'bing-ads';
    if (!ft.referrer_host) return 'direct';
    const h = ft.referrer_host.toLowerCase();
    if (h.includes('google.')) return 'google-organic';
    if (h.includes('bing.')) return 'bing-organic';
    if (h.includes('duckduckgo.')) return 'duckduckgo-organic';
    if (h.includes('chat.openai.') || h.includes('chatgpt.')) return 'chatgpt';
    if (h.includes('perplexity.')) return 'perplexity';
    if (h.includes('claude.') || h.includes('anthropic.')) return 'claude';
    if (h.includes('gemini.') || h.includes('bard.')) return 'gemini';
    if (h.includes(window.location.hostname)) return 'internal';
    return 'referral-' + h;
  }

  const attribution = getOrSetFirstTouch();

  const appliedFromUrl = document.getElementById('fc-applied-from-url');
  if (appliedFromUrl) appliedFromUrl.value = window.location.href;

  function logToSupabase(data) {
    if (!cfg.supabase) return;
    const basePayload = {
      ...data,
      page_url: window.location.href,
      applied_from: cfg.appliedFrom,
      user_agent: navigator.userAgent,
    };
    const fullPayload = {
      ...basePayload,
      source: inferSource(attribution),
      landing_path: attribution.landing_path,
      referrer: attribution.referrer,
      referrer_host: attribution.referrer_host,
      utm_source: attribution.utm_source,
      utm_medium: attribution.utm_medium,
      utm_campaign: attribution.utm_campaign,
      utm_term: attribution.utm_term,
      utm_content: attribution.utm_content,
      gclid: attribution.gclid,
      fbclid: attribution.fbclid,
      msclkid: attribution.msclkid,
    };
    const post = (body) =>
      fetch(`${cfg.supabase.url}/rest/v1/${cfg.supabase.table}`, {
        method: 'POST',
        headers: {
          'apikey': cfg.supabase.anonKey,
          'Authorization': `Bearer ${cfg.supabase.anonKey}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify(body),
      });
    // 3-tier write: full -> base -> safe (schema-confirmed columns only).
    // Guarantees a column drift on Supabase can never silently lose a lead.
    // Closes the Amy-Knight class of bug from MI on 8 May 2026 where a
    // missing `notes` column 400'd both full and base, and the lead died
    // in fetch.catch(). The safe tier filters to columns the leadgen schema
    // is guaranteed to have (the CREATE TABLE in
    // ~/SUPABASE_MIGRATION_LEADGEN_LEAD_TABLES_2026-05-11.sql).
    const SAFE_COLUMNS = [
      'event_type', 'turnover', 'industry', 'finance_type',
      'company_name', 'company_number', 'business_postcode',
      'contact_name', 'email', 'phone',
      'page_url', 'applied_from', 'user_agent',
      'source', 'landing_path', 'referrer', 'referrer_host',
      'utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content',
      'gclid', 'fbclid', 'msclkid'
    ];
    const safePayload = {};
    SAFE_COLUMNS.forEach(k => { if (fullPayload[k] !== undefined) safePayload[k] = fullPayload[k]; });
    (async () => {
      try {
        const r1 = await post(fullPayload);
        if (r1.ok) return;
        const r2 = await post(basePayload);
        if (r2.ok) return;
        const r3 = await post(safePayload);
        if (r3.ok) return;
        const err = await r3.text();
        console.error('[fleet-core LeadForm] Supabase write failed all retries:', r3.status, err);
      } catch (e) {
        console.error('[fleet-core LeadForm] Supabase write threw:', e);
      }
    })();
  }

  function notifyPartialFill(turnover, industry, financeType, company) {
    if (!cfg.partialFillEmail) return;
    try {
      fetch(`https://formsubmit.co/ajax/${cfg.partialFillEmail}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          _subject: `${cfg.emailSubject} — ${company || 'someone'} started a quote`,
          _template: 'table',
          company: company || 'Not entered',
          turnover, industry, finance_type: financeType,
          applied_from: cfg.appliedFrom,
          page_url: window.location.href,
          // Attribution carries through to partial-fill notifications too
          lead_source: inferSource(attribution),
          landing_path: attribution.landing_path || '',
          referrer: attribution.referrer || '(direct)',
          utm_source: attribution.utm_source || '',
          utm_campaign: attribution.utm_campaign || '',
          gclid: attribution.gclid || '',
          fbclid: attribution.fbclid || '',
          note: 'Step 1 complete; not yet submitted. May still be filling step 2.',
        }),
      }).catch(() => {});
    } catch {}
  }

  function trackEvent(name, params) {
    if (typeof window.gtag === 'function') window.gtag('event', name, params || {});
    window.dispatchEvent(new CustomEvent('fc-leadform', { detail: { event: name, ...params } }));
  }

  trackEvent('form_view', { applied_from: cfg.appliedFrom });

  // Inline-error helpers (replace alert() — modern UX)
  function showError(fieldId) {
    const err = document.getElementById(fieldId + '-error');
    if (err) err.removeAttribute('hidden');
    const input = document.getElementById(fieldId);
    if (input) input.style.borderColor = '#fca5a5';
  }
  function clearError(fieldId) {
    const err = document.getElementById(fieldId + '-error');
    if (err) err.setAttribute('hidden', '');
    const input = document.getElementById(fieldId);
    if (input) input.style.borderColor = '';
  }
  function setStep(n) {
    const num = document.getElementById('fc-step-num');
    if (num) num.textContent = String(n);
  }

  document.getElementById('fc-next-step')?.addEventListener('click', () => {
    const turnover = document.getElementById('fc-turnover')?.value;
    const industry = document.getElementById('fc-industry')?.value;
    const financeType = document.getElementById('fc-finance-type')?.value;

    // Inline validation — clear any prior errors then re-flag
    let hasError = false;
    [['fc-turnover', turnover], ['fc-industry', industry], ['fc-finance-type', financeType]].forEach(([id, v]) => {
      if (!v) { showError(id); hasError = true; } else { clearError(id); }
    });
    if (hasError) return;

    document.getElementById('fc-step-1').setAttribute('hidden', '');
    document.getElementById('fc-step-2').removeAttribute('hidden');
    setStep(2);
    // Focus first field on step 2 for keyboard users
    document.getElementById('fc-company')?.focus();

    trackEvent('form_step_2', { turnover, industry, finance_type: financeType, applied_from: cfg.appliedFrom });
    logToSupabase({
      event_type: 'step_1_complete',
      turnover, industry, finance_type: financeType,
    });
    // Step-1 partial-fill notification fires only after step 1 — but we don't have company yet.
    // Send the email at step 1 with placeholder for company; if they finish, the full-submit email overrides.
    notifyPartialFill(turnover, industry, financeType, '');
  });

  document.getElementById('fc-prev-step')?.addEventListener('click', () => {
    document.getElementById('fc-step-2').setAttribute('hidden', '');
    document.getElementById('fc-step-1').removeAttribute('hidden');
    setStep(1);
    trackEvent('form_step_back');
  });

  // Clear inline errors as the user fixes the field
  ['fc-turnover', 'fc-industry', 'fc-finance-type'].forEach(id => {
    document.getElementById(id)?.addEventListener('change', () => clearError(id));
  });
  ['fc-company', 'fc-name', 'fc-email', 'fc-phone'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', () => clearError(id));
  });
  // Reset the company error text back to default when the user edits the company
  // field, so the postcode-prompt message doesn't linger after they fix it.
  const companyErrEl = document.getElementById('fc-company-error');
  const COMPANY_ERROR_DEFAULT = companyErrEl ? companyErrEl.textContent : '';
  document.getElementById('fc-company')?.addEventListener('input', () => {
    if (companyErrEl) companyErrEl.textContent = COMPANY_ERROR_DEFAULT;
  });
  // Clear postcode-visible error as the user types; also keep hidden postcode
  // in sync so FormData carries the latest value if they don't blur first.
  document.getElementById('fc-business-postcode-visible')?.addEventListener('input', (e) => {
    clearError('fc-business-postcode-visible');
    const hidden = document.getElementById('fc-business-postcode');
    if (hidden) hidden.value = e.target.value;
  });

  let chTimeout;
  const companyInput = document.getElementById('fc-company');
  const chResults = document.getElementById('fc-ch-results');
  const chInfo = document.getElementById('fc-ch-info');

  if (cfg.companiesHouseProxyPath) {
    companyInput?.addEventListener('input', () => {
      clearTimeout(chTimeout);
      const q = companyInput.value.trim();
      if (q.length < 3) { chResults?.setAttribute('hidden', ''); return; }
      chTimeout = setTimeout(async () => {
        try {
          // Same-origin proxy. Host site's Pages Function holds the API key
          // in env so it never reaches the client bundle.
          const res = await fetch(`${cfg.companiesHouseProxyPath}?q=${encodeURIComponent(q)}`);
          if (!res.ok) return;
          const data = await res.json();
          if (!data.items?.length) { chResults?.setAttribute('hidden', ''); return; }
          // CH search response shape: each item has an `address` object with
          // `postal_code` (plus locality, region, etc.). We pull postal_code at
          // pick-time so the form ships business_postcode without asking the
          // user. Escape quotes defensively for the data-* attribute round-trip.
          const escapeAttr = (s) => String(s || '').replace(/"/g, '&quot;');
          chResults.innerHTML = data.items.map(c => {
            const postalCode = (c.address && c.address.postal_code) || '';
            return `<div class="fc-leadform__ch-item" data-name="${escapeAttr(c.title)}" data-number="${escapeAttr(c.company_number)}" data-status="${escapeAttr(c.company_status)}" data-postcode="${escapeAttr(postalCode)}">
              <div class="fc-leadform__ch-name">${c.title}</div>
              <div class="fc-leadform__ch-meta">${c.company_number} · ${c.company_status} · ${c.address_snippet || ''}</div>
            </div>`;
          }).join('');
          chResults.removeAttribute('hidden');
          chResults.querySelectorAll('.fc-leadform__ch-item').forEach(item => {
            item.addEventListener('click', () => {
              const name = item.getAttribute('data-name') || '';
              const number = item.getAttribute('data-number') || '';
              const status = item.getAttribute('data-status') || '';
              const postcode = item.getAttribute('data-postcode') || '';
              companyInput.value = name;
              document.getElementById('fc-company-number').value = number;
              document.getElementById('fc-company-status').value = status;
              // Populate the hidden business_postcode from CH address.postal_code.
              // If CH didn't return a postcode (rare for active UK companies),
              // leave it empty — the submit-time fallback will prompt the user.
              const postcodeInput = document.getElementById('fc-business-postcode');
              if (postcodeInput) postcodeInput.value = postcode;
              // If the manual fallback was previously revealed, hide it again.
              const fallback = document.getElementById('fc-postcode-fallback');
              if (fallback && postcode) fallback.setAttribute('hidden', '');
              chResults.setAttribute('hidden', '');
              chInfo.textContent = `✓ ${name} (${number}) — ${status}`;
              chInfo.removeAttribute('hidden');
              trackEvent('company_selected', { company_name: name, company_number: number, has_postcode: postcode ? 'yes' : 'no' });
            });
          });
        } catch {}
      }, 300);
    });
    document.addEventListener('click', (e) => {
      if (!e.target.closest('#fc-company, #fc-ch-results')) {
        chResults?.setAttribute('hidden', '');
      }
    });
  }

  const emailInput = document.getElementById('fc-email');
  const emailError = document.getElementById('fc-email-error');
  emailInput?.addEventListener('blur', () => {
    const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value);
    if (emailInput.value && !valid) emailError.removeAttribute('hidden');
    else emailError.setAttribute('hidden', '');
  });
  const phoneInput = document.getElementById('fc-phone');
  const phoneError = document.getElementById('fc-phone-error');
  phoneInput?.addEventListener('blur', () => {
    const cleaned = phoneInput.value.replace(/[\s\(\)\-]/g, '');
    const valid = /^(\+44|0)[1-9]\d{8,10}$/.test(cleaned);
    if (phoneInput.value && !valid) phoneError.removeAttribute('hidden');
    else phoneError.setAttribute('hidden', '');
  });

  const form = document.getElementById('fc-lead-form');
  let abandonTimer;
  // UK postcode regex — accepts standard formats with or without internal space.
  // Source: GOV.UK Bulk Data Transfer (BS7666) tolerant variant.
  const UK_POSTCODE_RE = /^[A-Z]{1,2}\d[A-Z\d]?\s*\d[A-Z]{2}$/i;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    let hasError = false;
    const company = document.getElementById('fc-company').value;
    if (!company || company.length < 2) { showError('fc-company'); hasError = true; }

    // Business postcode: should already be populated from CH autocomplete. If
    // empty (user typed a company without picking, or CH had no postcode for
    // that record), reveal the manual fallback input and require it.
    const postcodeHidden = document.getElementById('fc-business-postcode');
    const postcodeFallback = document.getElementById('fc-postcode-fallback');
    const postcodeVisible = document.getElementById('fc-business-postcode-visible');
    const hiddenPostcode = postcodeHidden ? postcodeHidden.value.trim() : '';
    const visiblePostcode = postcodeVisible ? postcodeVisible.value.trim() : '';
    // Prefer the visible input if user filled it (covers the case where they
    // hand-corrected a CH-supplied postcode). Otherwise use the hidden value.
    const effectivePostcode = visiblePostcode || hiddenPostcode;
    if (!effectivePostcode) {
      // Reveal fallback, flag the company field so the user sees the link, and
      // block submit. The inline note inside the fallback explains why.
      if (postcodeFallback) postcodeFallback.removeAttribute('hidden');
      showError('fc-company');
      const companyErr = document.getElementById('fc-company-error');
      if (companyErr) companyErr.textContent = "We couldn't find your registered address. Please add your business postcode below.";
      if (postcodeVisible) postcodeVisible.focus();
      hasError = true;
    } else if (!UK_POSTCODE_RE.test(effectivePostcode)) {
      // We have something but it doesn't look like a UK postcode. Only show
      // the visible-input error if the fallback is open (i.e. user typed it).
      if (postcodeFallback && !postcodeFallback.hasAttribute('hidden')) {
        showError('fc-business-postcode-visible');
        hasError = true;
      } else {
        // Hidden postcode from CH was malformed (very rare). Reveal fallback
        // and ask the user to confirm.
        if (postcodeFallback) postcodeFallback.removeAttribute('hidden');
        if (postcodeVisible) {
          postcodeVisible.value = effectivePostcode;
          postcodeVisible.focus();
        }
        showError('fc-business-postcode-visible');
        hasError = true;
      }
    } else {
      // Sync the effective value back into the hidden field so the FormData
      // payload always carries the final postcode (whether CH-sourced or
      // user-edited).
      if (postcodeHidden) postcodeHidden.value = effectivePostcode;
      clearError('fc-business-postcode-visible');
    }

    const name = document.getElementById('fc-name').value;
    if (!name || name.length < 2) { showError('fc-name'); hasError = true; }

    const email = document.getElementById('fc-email').value;
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('fc-email'); hasError = true; }

    const phone = document.getElementById('fc-phone').value.replace(/[\s\(\)\-]/g, '');
    if (!/^(\+44|0)[1-9]\d{8,10}$/.test(phone)) { showError('fc-phone'); hasError = true; }

    if (hasError) return;

    const fd = new FormData(form);
    const data = Object.fromEntries(fd);
    data._subject = cfg.emailSubject;
    data._template = 'table';
    // Auto-acknowledgement to the lead (FormSubmit feature) — sent from cfg.partialFillEmail
    if (cfg.partialFillEmail) {
      data._autoresponse = `Thanks. We've received your application and will route it to UK lenders most likely to approve based on your sector and ticket size. Expect to hear from a matched broker within 24 hours.\n\nIf you didn't submit this, ignore this email.`;
    }
    data.page_url = window.location.href;

    // Merge first-touch attribution into the email payload so source / UTM /
    // referrer / click IDs are visible in the lead email even when Supabase
    // logging isn't configured. Fields are intentionally human-readable for
    // FormSubmit's table template.
    const inferredSource = inferSource(attribution);
    data.lead_source = inferredSource;
    data.landing_path = attribution.landing_path || '';
    data.referrer = attribution.referrer || '(direct)';
    data.referrer_host = attribution.referrer_host || '';
    data.utm_source = attribution.utm_source || '';
    data.utm_medium = attribution.utm_medium || '';
    data.utm_campaign = attribution.utm_campaign || '';
    data.utm_term = attribution.utm_term || '';
    data.utm_content = attribution.utm_content || '';
    data.gclid = attribution.gclid || '';
    data.fbclid = attribution.fbclid || '';
    data.msclkid = attribution.msclkid || '';
    data.session_started_at = attribution.session_started_at || '';

    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }

    try {
      const res = await fetch(cfg.submitEndpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();
      if (result.success) {
        trackEvent('form_submit_success', {
          company: data.company,
          turnover: data.turnover,
          finance_type: data.finance_type,
          applied_from: cfg.appliedFrom,
        });
        clearTimeout(abandonTimer);
        logToSupabase({
          event_type: 'form_submit',
          turnover: data.turnover,
          industry: data.industry,
          finance_type: data.finance_type,
          company_name: data.company,
          company_number: data.company_number || null,
          business_postcode: data.business_postcode || null,
          contact_name: data.name,
          email: data.email,
          phone: data.phone,
        });
        form.innerHTML = cfg.successHTML;
      } else {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit application →'; }
        trackEvent('form_submit_error');
      }
    } catch {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit application →'; }
      trackEvent('form_submit_error');
    }
  });

  const observer = new MutationObserver(() => {
    const step2 = document.getElementById('fc-step-2');
    if (step2 && !step2.hasAttribute('hidden')) {
      abandonTimer = setTimeout(() => {
        const name = document.getElementById('fc-name')?.value;
        const email = document.getElementById('fc-email')?.value;
        const turnover = document.getElementById('fc-turnover')?.value;
        const industry = document.getElementById('fc-industry')?.value;
        const financeType = document.getElementById('fc-finance-type')?.value;
        trackEvent('form_abandon_step2', {
          partial_data: (name || email) ? 'started' : 'none',
          has_name: name ? 'yes' : 'no',
          has_email: email ? 'yes' : 'no',
          applied_from: cfg.appliedFrom,
        });
        logToSupabase({
          event_type: 'form_abandon',
          turnover: turnover || null,
          industry: industry || null,
          finance_type: financeType || null,
          contact_name: name || null,
          email: email || null,
        });
      }, 300000);
    } else {
      clearTimeout(abandonTimer);
    }
  });
  const step2El = document.getElementById('fc-step-2');
  if (step2El) observer.observe(step2El, { attributes: true, attributeFilter: ['hidden'] });
</script>

