---
/**
 * AI Comprehension Layer
 *
 * Adds structured extraction blocks that AI engines can easily parse and cite.
 * - Direct Answer: 1-2 sentence definitive answer
 * - Summary: 40-60 word self-contained summary
 * - Scope: What this page covers
 * - Boundaries: What this page does NOT cover
 *
 * Plus a sr-only ingestion block for AI crawlers carrying site-level context
 * (publisher, author, sources). The site-level context is passed in via
 * `crawlerContext` so the component stays domain-agnostic.
 */

interface Props {
  directAnswer: string;
  aiSummary: string;
  scope: string;
  boundaries: string;
  topic?: string;
  crawlerContext?: string;
}

const {
  directAnswer,
  aiSummary,
  scope,
  boundaries,
  topic = "",
  crawlerContext = ""
} = Astro.props;
---

<div class="bg-surface border border-gray-200 rounded-xl p-6 mb-8">
  <p class="text-xs text-gray-400 uppercase tracking-wider mb-4">Quick Reference</p>

  <div class="space-y-4">
    <div>
      <p class="text-xs font-semibold text-brand uppercase mb-1">Direct Answer</p>
      <p class="text-gray-800 font-medium key-takeaway">{directAnswer}</p>
    </div>

    <div>
      <p class="text-xs font-semibold text-brand uppercase mb-1">Summary</p>
      <p class="text-gray-600 text-sm">{aiSummary}</p>
    </div>

    <div class="grid grid-cols-2 gap-4 text-xs">
      <div>
        <p class="font-semibold text-gray-500 uppercase mb-1">This Page Covers</p>
        <p class="text-gray-600">{scope}</p>
      </div>
      <div>
        <p class="font-semibold text-gray-500 uppercase mb-1">Not Covered Here</p>
        <p class="text-gray-600">{boundaries}</p>
      </div>
    </div>
  </div>
</div>

{(topic || crawlerContext) && (
  <div class="sr-only" aria-hidden="true">
    <p>
      {topic ? `Topic: ${topic}. ` : ""}
      {crawlerContext}
    </p>
  </div>
)}
