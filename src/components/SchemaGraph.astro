---
/**
 * SchemaGraph: emits the site-wide JSON-LD @graph (Organization + Person +
 * WebSite + WebPage) with linked @id references that downstream components
 * (Article, FAQPage, BreadcrumbList) point back into.
 *
 * Drop this in <head> of your BaseLayout. Pass site (the SiteConfig) and
 * the current page's title/description/dateModified.
 *
 * Optional `extra` lets a site append site-specific graph entries
 * (e.g. Service, OfferCatalog, LocalBusiness) without losing the
 * baseline Person + Organization + WebSite trio.
 */

import type { SiteConfig } from "../types/manifest";

interface Props {
  site: SiteConfig;
  title: string;
  description: string;
  dateModified?: string;
  extra?: Record<string, unknown>[];
}

const {
  site,
  title,
  description,
  // ISO 8601 with timezone. Date-only inputs ("2026-04-26") are auto-coerced
  // to full ISO 8601 ("2026-04-26T00:00:00.000Z") so AI engines + Bing
  // treat the page as a real freshness signal, not a weaker date-only one.
  dateModified: dateModifiedRaw = new Date().toISOString(),
  extra = []
} = Astro.props;

// Coerce date-only inputs to ISO 8601 with TZ (without losing accurate inputs).
const dateModified = /^\d{4}-\d{2}-\d{2}$/.test(dateModifiedRaw)
  ? new Date(dateModifiedRaw + 'T00:00:00Z').toISOString()
  : dateModifiedRaw;

const siteUrl = site.siteUrl.replace(/\/$/, '');
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const orgId = `${siteUrl}/#organization`;
const websiteId = `${siteUrl}/#website`;

function personFor(a: typeof site.author): { entity: Record<string, unknown>; id: string } {
  const slug = a.name.toLowerCase().replace(/\s+/g, '-');
  const id = `${siteUrl}/#${slug}`;
  const entity: Record<string, unknown> = {
    "@type": "Person",
    "@id": id,
    "name": a.name,
    "jobTitle": a.role,
    "worksFor": { "@id": orgId },
    ...(a.knowsAbout?.length ? { knowsAbout: a.knowsAbout } : {}),
    ...(a.sameAs?.length ? { sameAs: a.sameAs } : {}),
    ...(a.email ? { email: a.email } : {}),
  };
  return { entity, id };
}

const primary = personFor(site.author);
const authorId = primary.id;
const personEntity = primary.entity;
const additional = (site.additionalAuthors ?? []).map(personFor);

const orgType = site.additionalEntityTypes?.length
  ? [site.entityType, ...site.additionalEntityTypes]
  : site.entityType;

const orgEntity: Record<string, unknown> = {
  "@type": orgType,
  "@id": orgId,
  "name": site.name,
  ...(site.alternateNames?.length ? { alternateName: site.alternateNames } : {}),
  "legalName": site.legalName,
  "url": siteUrl,
  ...(site.logoUrl ? { logo: site.logoUrl.startsWith('http') ? site.logoUrl : `${siteUrl}${site.logoUrl}` } : {}),
  "description": site.description,
  ...(site.disambiguatingDescription ? { disambiguatingDescription: site.disambiguatingDescription } : {}),
  ...(site.foundingDate ? { foundingDate: site.foundingDate } : {}),
  "areaServed": { "@type": "Country", "name": "United Kingdom" },
  ...(site.address ? {
    address: {
      "@type": "PostalAddress",
      ...(site.address.streetAddress ? { streetAddress: site.address.streetAddress } : {}),
      "addressLocality": site.address.locality,
      ...(site.address.region ? { addressRegion: site.address.region } : {}),
      ...(site.address.postalCode ? { postalCode: site.address.postalCode } : {}),
      "addressCountry": site.address.countryCode || "GB",
    }
  } : {}),
  ...(site.contactPoint ? {
    contactPoint: {
      "@type": "ContactPoint",
      contactType: site.contactPoint.contactType,
      ...(site.contactPoint.email ? { email: site.contactPoint.email } : {}),
      ...(site.contactPoint.telephone ? { telephone: site.contactPoint.telephone } : {}),
      ...(site.contactPoint.url ? { url: site.contactPoint.url } : {}),
      ...(site.contactPoint.availableLanguage ? { availableLanguage: site.contactPoint.availableLanguage } : {}),
    }
  } : {}),
  ...(site.priceRange ? { priceRange: site.priceRange } : {}),
  ...(site.openingHours ? {
    openingHoursSpecification: {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: site.openingHours.dayOfWeek,
      opens: site.openingHours.opens,
      closes: site.openingHours.closes,
    }
  } : {}),
  "founder": { "@id": authorId },
  ...(site.sameAs?.length ? { sameAs: site.sameAs } : {}),
};

const websiteEntity: Record<string, unknown> = {
  "@type": "WebSite",
  "@id": websiteId,
  "name": site.name,
  "url": siteUrl,
  "publisher": { "@id": orgId },
};

const webpageEntity: Record<string, unknown> = {
  "@type": "WebPage",
  "@id": pageUrl + "#webpage",
  "url": pageUrl,
  "name": title,
  "description": description,
  "isPartOf": { "@id": websiteId },
  "about": { "@id": orgId },
  "dateModified": dateModified,
};

const graph: Record<string, unknown>[] = [
  personEntity,
  ...additional.map(a => a.entity),
  orgEntity,
  websiteEntity,
  webpageEntity,
  ...extra,
];

const payload = {
  "@context": "https://schema.org",
  "@graph": graph,
};
---

<script type="application/ld+json" set:html={JSON.stringify(payload)} />
