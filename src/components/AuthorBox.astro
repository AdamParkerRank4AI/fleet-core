---
/**
 * AuthorBox: the named-author byline block that ships at the end of every
 * article. E-E-A-T signal for AI citation engines.
 *
 * Pass an AuthorConfig (or rely on the manifest's default at runtime).
 */

import type { AuthorConfig } from "../types/manifest";

interface Props {
  author: AuthorConfig;
  brandLine?: string;
  dateModified?: string;
}

const { author, brandLine = "", dateModified = new Date().toISOString().slice(0, 10) } = Astro.props;

const formattedDate = new Date(dateModified + 'T00:00:00').toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<div class="flex items-start gap-4 border-t border-gray-200 pt-6 mt-10">
  <div class="w-12 h-12 bg-brand rounded-full flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
    {author.initials}
  </div>
  <div>
    <p class="font-semibold text-gray-900">
      {author.bylineLink ? (
        <a href={author.bylineLink} class="hover:text-brand transition-colors">{author.name}</a>
      ) : (
        author.name
      )}
    </p>
    <p class="text-sm text-gray-500">{author.role}{brandLine ? `, ${brandLine}` : ""}</p>
    <p class="text-sm text-gray-600 mt-1">{author.bio}</p>
    <p class="text-xs text-gray-400 mt-2">Last reviewed: {formattedDate}</p>
  </div>
</div>
