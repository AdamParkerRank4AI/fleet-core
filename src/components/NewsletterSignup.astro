---
/**
 * NewsletterSignup: simple newsletter signup form.
 *
 * Posts to a configured endpoint (FormSubmit by default). Renders an
 * email field, optional name field, and a submit button.
 */

interface Props {
  endpoint: string;
  collectName?: boolean;
  consentText?: string;
  buttonLabel?: string;
  successPath?: string;
}

const {
  endpoint,
  collectName = false,
  consentText = "I agree to receive newsletter emails. I can unsubscribe any time.",
  buttonLabel = "Subscribe",
  successPath = "/thanks/",
} = Astro.props;
---

<form class="newsletter-form space-y-3 bg-surface border border-gray-200 rounded-xl p-5" method="post" action={endpoint}>
  <input type="hidden" name="_subject" value="Newsletter signup" />
  <input type="hidden" name="_next" value={successPath} />
  <input type="hidden" name="_captcha" value="false" />

  {collectName && (
    <div>
      <label for="newsletter-name" class="block text-xs font-bold text-gray-700 mb-1">Your name</label>
      <input id="newsletter-name" name="name" type="text" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
    </div>
  )}

  <div>
    <label for="newsletter-email" class="block text-xs font-bold text-gray-700 mb-1">Email</label>
    <input id="newsletter-email" name="email" type="email" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
  </div>

  <label class="flex items-start gap-2 text-xs text-gray-700">
    <input type="checkbox" name="consent" required class="mt-0.5" />
    <span>{consentText}</span>
  </label>

  <button type="submit" class="w-full bg-brand text-white px-4 py-2 rounded-lg text-sm font-bold hover:shadow-lg transition">
    {buttonLabel}
  </button>
</form>
